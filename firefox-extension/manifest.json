{
  "manifest_version": 2,
  "name": "OBS YouTube Bridge",
  "version": "1.0.0",
  "description": "Envoie les données YouTube vers l'overlay OBS",
  "permissions": [
    "tabs",
    "https://www.youtube.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://music.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_title": "OBS YouTube Bridge"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "obs-youtube-bridge@local",
      "strict_min_version": "109.0"
    }
  }
}
